GEMINI_API_KEY=your_gemini_api_key_here

# Answer-generation model (Gemini API, free-tier Gemma).
GEMMA_MODEL=gemma-4-31b-it

# RAGAS judge runs on OpenRouter — separate provider + model family from
# the generator, to reduce self-bias on faithfulness scoring.
RAGAS_JUDGE_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OCR model (scanned-page text extraction) and the text-embedding model.
OCR_MODEL=gemini-3.1-flash-lite
EMBEDDING_MODEL=models/gemini-embedding-001

GITHUB_TOKEN=your_github_token_here
GITHUB_MODEL=gpt-4o
GITHUB_API_BASE=https://models.inference.ai.azure.com

REDIS_URL=redis://localhost:6379
CHROMA_PERSIST_DIR=./chroma_store

SENTRY_DSN=

CHUNK_SIZE=1024
CHUNK_OVERLAP=50
TOP_K=8
CACHE_TTL=86400
LOG_LEVEL=INFO
