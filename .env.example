GEMINI_API_KEY=your_gemini_api_key_here

# Answer-generation model, and the model RAGAS uses to judge eval metrics.
# Both default to Gemma for its generous free-tier quota; both have working defaults.
GEMMA_MODEL=gemma-4-31b-it
RAGAS_JUDGE_MODEL=gemma-4-31b-it

# OCR model (scanned-page text extraction) and the text-embedding model.
OCR_MODEL=gemini-3.1-flash-lite
EMBEDDING_MODEL=models/gemini-embedding-2

GITHUB_TOKEN=your_github_token_here
GITHUB_MODEL=gpt-4o
GITHUB_API_BASE=https://models.inference.ai.azure.com

REDIS_URL=redis://localhost:6379
CHROMA_PERSIST_DIR=./chroma_store

SENTRY_DSN=

CHUNK_SIZE=1024
CHUNK_OVERLAP=50
TOP_K=8
CACHE_TTL=86400
LOG_LEVEL=INFO
